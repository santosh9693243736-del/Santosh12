            <div class="auth-body">
                <div class="auth-input-wrapper">
                    <span class="auth-icon">👤</span>
                    <input type="text" id="adminIdInput" placeholder="एडमिन यूजर आईडी डालें">
                </div>
                <div class="auth-input-wrapper">
                    <span class="auth-icon">🔒</span>
                    <input type="password" id="adminPinInput" placeholder="एडमिन पिन डालें">
                </div>
                <button class="auth-btn" style="background: linear-gradient(135deg, #c0392b, #8e44ad); box-shadow: 0 6px 0 #7a120b, 0 10px 15px rgba(192,57,43,0.3);" type="button" onclick="superAdminLogin()">एडमिन लॉग इन</button>
                <div class="text-center mt-15">
                    <button class="link-btn" style="color: #c0392b;" type="button" onclick="showScreen('screenLogin')">← वापस लेबर लॉगिन पर जाएँ</button>
                </div>
            </div>
        </div>
    </div>

    <div id="screenRegister" class="screen auth-wrapper hidden">
        <div class="auth-card">
            <div class="auth-header" style="background: linear-gradient(135deg, #0f9d58, #0b7a44);">
                <div class="auth-logo" style="color: #0f9d58;">👷‍♂️</div>
                <h2>नया अकाउंट</h2>
                <p>अपनी जानकारी दर्ज करें</p>
            </div>
            <div class="auth-body">
                <div class="auth-input-wrapper">
                    <span class="auth-icon">⚙️</span>
                    <select id="regRole">
                        <option value="लेबर">लेबर (Member)</option>
                        <option value="सुपरवाइजर">सुपरवाइजर (Supervisor)</option>
                        <option value="इंजीनियर">इंजीनियर (Engineer)</option>
                        <option value="ठेकेदार">ठेकेदार (Contractor)</option>
                    </select>
                </div>
                <div class="auth-input-wrapper"><span class="auth-icon">👤</span><input type="text" id="regName" placeholder="अपना पूरा नाम लिखें"></div>
                <div class="auth-input-wrapper"><span class="auth-icon">📞</span><input type="tel" id="regMobile" placeholder="10 अंकों का मोबाइल नंबर"></div>
                <div class="auth-input-wrapper"><span class="auth-icon">🔑</span><input type="password" id="regPin" placeholder="नया 4 अंकों का पिन सेट करें"></div>
                
                <button class="auth-btn" style="background: linear-gradient(135deg, #0f9d58, #0b7a44); box-shadow: 0 6px 0 #054f2a, 0 10px 15px rgba(15,157,88,0.3);" type="button" onclick="registerUser()">रजिस्टर करें</button>
                <div class="text-center mt-15"><button class="link-btn" style="color: #0f9d58;" type="button" onclick="showScreen('screenLogin')">← वापस लॉगिन पर जाएँ</button></div>
            </div>
        </div>
    </div>

    <div id="screenDash" class="screen hidden no-print" style="margin-top: 20px;">
        <div class="header-bar">
            <span>🛡️ <b id="dashTitle">डैशबोर्ड</b></span>
            <button class="btn btn-danger" type="button" style="width: auto; padding: 8px 15px; font-size: 13px; margin:0;" onclick="logout()">लॉग आउट</button>
